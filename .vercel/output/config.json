{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/editor/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/posts/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/research/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/settings/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/subscribers/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/?$",
			"dest": "_render"
		},
		{
			"src": "^/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/([^/]+?)/articles/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/([^/]+?)/profile/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}