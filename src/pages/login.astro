---
import LoginView from '../components/auth/LoginView';
import SEO from '../components/shared/SEO.astro';
import '../styles/global.css';

// We want the login page to be very clean, so we don't use the standard Layout with Header/Footer
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SEO 
      title="Login | Bloom Brief"
      description="Access your premium horticultural intelligence dashboard."
    />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Montserrat:wght@800;900&display=swap" rel="stylesheet">
  </head>
  <body class="bg-[#F8FAFC]">
    <main>
      <LoginView client:load />
    </main>
    
    <style is:global>
      :root {
        --font-heading: 'Montserrat', sans-serif;
        --font-sans: 'Inter', sans-serif;
      }
      
      body {
        font-family: var(--font-sans);
        margin: 0;
        padding: 0;
      }

      .font-heading {
        font-family: var(--font-heading);
      }
    </style>
  </body>
</html>
