---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getAdminPosts, getSubscribers } from '../../lib/dataService';

const posts = await getAdminPosts(Astro.locals.supabase);
const subscribers = await getSubscribers(Astro.locals.supabase);

const stats = {
  total: posts.length,
  research: posts.filter(p => p.is_research).length,
  drafts: posts.filter(p => p.draft).length,
  audience: subscribers.length,
};

const recentPosts = posts.slice(0, 5);
---

<AdminLayout title="Overview">

  <!-- Stats Grid -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <div class="stat-card-blue rounded p-5">
      <p class="text-blue-200 text-[10px] font-black uppercase tracking-widest mb-2">Total Articles</p>
      <p class="text-3xl font-heading font-black">{stats.total}</p>
    </div>
    <div class="stat-card-green rounded p-5">
      <p class="text-green-200 text-[10px] font-black uppercase tracking-widest mb-2">Research Papers</p>
      <p class="text-3xl font-heading font-black">{stats.research}</p>
    </div>
    <div class="stat-card-sky rounded p-5">
      <p class="text-sky-200 text-[10px] font-black uppercase tracking-widest mb-2">Active Drafts</p>
      <p class="text-3xl font-heading font-black">{stats.drafts}</p>
    </div>
    <div class="stat-card-gold rounded p-5">
      <p class="text-amber-200 text-[10px] font-black uppercase tracking-widest mb-2">Newsletter Leads</p>
      <p class="text-3xl font-heading font-black">{stats.audience}</p>
    </div>
  </div>

  <!-- Content Grid -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

    <!-- Recent Dispatches Table -->
    <div class="lg:col-span-2 admin-card">
      <div class="flex justify-between items-center mb-5 pb-4 border-b border-gray-100">
        <div>
          <h2 class="text-sm font-heading font-extrabold text-gray-900 uppercase tracking-wider">Recent Articles</h2>
          <p class="text-xs text-gray-400 font-medium mt-0.5">Your five most recent articles and research items</p>
        </div>
        <a href="/admin/posts/" class="text-xs font-black text-[#00A8E8] hover:text-[#003366] transition uppercase tracking-widest">All Posts →</a>
      </div>

      <div class="overflow-x-auto admin-table">
        <table class="w-full text-left">
          <thead>
            <tr class="text-[10px] font-black text-gray-400 uppercase tracking-widest border-b border-gray-100">
              <th class="pb-3">Title</th>
              <th class="pb-3 text-center">Type</th>
              <th class="pb-3 text-center">Status</th>
              <th class="pb-3 text-right">Action</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-50">
            {recentPosts.map(post => (
              <tr>
                <td class="py-4 pr-4">
                  <p class="font-semibold text-gray-800 text-sm leading-tight line-clamp-1">{post.title_en}</p>
                  <p class="text-[10px] text-gray-400 font-mono mt-0.5">{post.slug}</p>
                </td>
                <td class="py-4 text-center">
                  <span class={`px-2.5 py-1 rounded text-[10px] font-black uppercase tracking-widest ${post.is_research ? 'bg-[#1B4332]/10 text-[#1B4332]' : 'bg-[#003366]/10 text-[#003366]'}`}>
                    {post.is_research ? 'Research' : 'Article'}
                  </span>
                </td>
                <td class="py-4 text-center">
                  <span class={`px-2.5 py-1 rounded text-[10px] font-black uppercase tracking-widest ${post.draft ? 'badge-draft' : 'badge-live'}`}>
                    {post.draft ? 'Draft' : 'Live'}
                  </span>
                </td>
                <td class="py-4 text-right">
                  <a href={`/admin/editor?slug=${post.slug}`} class="text-[11px] font-black text-[#00A8E8] hover:text-[#003366] transition uppercase tracking-widest">Edit →</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Right Panel -->
    <div class="space-y-4">

      <!-- Info Card -->
      <div class="bg-[#003366] rounded p-6">
        <h3 class="font-heading font-extrabold text-white text-sm uppercase tracking-wider mb-3">Editorial Note</h3>
        <p class="text-sm text-blue-200 leading-relaxed mb-5">
          Ensure all articles include a high-resolution cover to maximise engagement on the Research Hub.
        </p>
        <a href="/admin/editor" class="block w-full py-2.5 bg-[#00A8E8] text-white text-center font-black text-xs uppercase tracking-widest rounded hover:bg-white hover:text-[#003366] transition-colors duration-200">
          + New Article
        </a>
      </div>

      <!-- Quick Links -->
      <div class="admin-card">
        <h3 class="text-[10px] font-black text-gray-400 uppercase tracking-widest mb-3">Quick Links</h3>
        <div class="space-y-1">
          {[
            { label: 'Research Hub', href: '/admin/research/' },
            { label: 'Subscribers', href: '/admin/subscribers/' },
            { label: 'All Posts', href: '/admin/posts/' },
            { label: 'Settings', href: '/admin/settings/' },
          ].map(link => (
            <a href={link.href} class="flex items-center justify-between py-2.5 px-3 rounded text-sm font-semibold text-gray-600 hover:bg-gray-50 hover:text-gray-900 transition-colors duration-150 group">
              {link.label}
              <span class="text-gray-300 group-hover:text-gray-500 transition-colors">→</span>
            </a>
          ))}
        </div>
      </div>

    </div>
  </div>
</AdminLayout>
