---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ResearchGrid from '../../../components/research/ResearchGrid';
import { getResearchPosts } from '../../../lib/dataService';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'am' } }
  ];
}

const { lang } = Astro.params;

// Fetch all technical research posts
const posts = await getResearchPosts();

const labels = {
  en: {
    title: "Technical Research Hub",
    subtitle: "Data-driven insights and market intelligence for the Ethiopian horticulture industry.",
    breadcrumbHome: "Home",
    breadcrumbResearch: "Research"
  },
  am: {
    title: "የቴክኒክ ምርምር ማዕከል",
    subtitle: "ለኢትዮጵያ የሆርቲካልቸር ኢንዱስትሪ በመረጃ የተደገፈ ግንዛቤ እና የገበያ መረጃ።",
    breadcrumbHome: "ዋና ገጽ",
    breadcrumbResearch: "ምርምር"
  }
}[lang as 'en' | 'am'];
---

<BaseLayout lang={lang} title={`${labels.title} | Bloom Brief`}>
  <!-- Hero / Header -->
  <div class="bg-gradient-to-b from-gray-900 to-primary text-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="text-sm text-blue-300 mb-6">
        <a href={`/${lang}/`} class="hover:text-white transition">{labels.breadcrumbHome}</a> &gt; <span>{labels.breadcrumbResearch}</span>
      </nav>
      <div class="max-w-3xl">
        <span class="inline-block px-3 py-1 bg-accent text-white text-xs font-black uppercase tracking-widest rounded mb-4">
          Expert Intelligence
        </span>
        <h1 class="text-4xl md:text-5xl font-heading font-extrabold mb-6 leading-tight">
          {labels.title}
        </h1>
        <p class="text-lg md:text-xl text-blue-100 opacity-90 leading-relaxed italic border-l-4 border-accent pl-6">
          "{labels.subtitle}"
        </p>
      </div>
    </div>
  </div>

  <!-- Interactive Hub Section -->
  <section class="py-16 pb-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <ResearchGrid posts={posts} lang={lang} client:load />
    </div>
  </section>
</BaseLayout>
