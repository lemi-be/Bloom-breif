---
import type { BlogPost } from '../../types/database';
import OptimizedImage from '../shared/OptimizedImage.astro';

interface Props {
  post: BlogPost;
  lang: string;
}

const { post, lang } = Astro.props;

const title = lang === 'en' ? post.title_en : post.title_am;
const description = lang === 'en' ? post.description_en : post.description_am;

const imageUrl = post.cover_image || 'default.jpg';
---

<article class="bg-white rounded-lg shadow-sm overflow-hidden border-t-4 border-primary transition-transform hover:-translate-y-1 hover:shadow-md flex flex-col h-full">
  <a href={`/${lang}/articles/${post.slug}/`} class="block overflow-hidden bg-gray-200">
    <OptimizedImage 
      src={imageUrl} 
      alt={title} 
      aspectRatio="4:3" 
      width={600}
    />
  </a>
  <div class="p-5 flex flex-col flex-grow">
    <div class="flex items-center gap-2 mb-3 flex-wrap">
      {post.is_research && (
        <span class="inline-block px-2 py-1 bg-brand text-white text-xs font-bold rounded self-start">
          {lang === 'en' ? 'Research' : 'ጥናት'}
        </span>
      )}
      {post.subscribers_only && (
        <span class="inline-flex items-center gap-1 px-2 py-1 bg-[#b45309] text-white text-xs font-bold rounded self-start">
          <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
          {lang === 'en' ? 'Subscribers Only' : 'ለደንበኞች ብቻ'}
        </span>
      )}
    </div>
    <h3 class="text-xl font-heading font-bold text-gray-900 mb-2 leading-tight">
      <a href={`/${lang}/articles/${post.slug}`} class="hover:text-primary transition">{title}</a>
    </h3>
    <p class="text-gray-600 text-sm mb-4 line-clamp-3">
      {description}
    </p>
    <div class="mt-auto">
      <a href={`/${lang}/articles/${post.slug}`} class="inline-flex items-center text-sm font-semibold text-accent hover:text-primary transition">
        {post.subscribers_only 
          ? (lang === 'en' ? 'Subscriber Access' : 'ለደንበኞች ብቻ') 
          : (lang === 'en' ? 'Read More' : 'ተጨማሪ ያንብቡ')
        } 
        <svg class="ml-1 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
      </a>
    </div>
  </div>
</article>
