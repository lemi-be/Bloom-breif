---
interface Props {
  title_en: string;
  title_am: string;
  desc_en: string;
  desc_am: string;
  icon: string;
  lang: string;
}

const { title_en, title_am, desc_en, desc_am, icon, lang } = Astro.props;
---

<div class="bg-white p-8 border-t-4 border-primary shadow-sm hover:shadow-md transition-shadow group">
  <div class="text-accent mb-6 transform group-hover:scale-110 transition-transform duration-300">
    <Fragment set:html={icon} />
  </div>
  <h3 class="text-xl font-heading font-bold text-primary mb-4">
    {lang === 'en' ? title_en : title_am}
  </h3>
  <p class="text-gray-600 text-sm leading-relaxed">
    {lang === 'en' ? desc_en : desc_am}
  </p>
</div>
